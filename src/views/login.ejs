<%- include('includes/head') %>
<%- include('includes/nav') %>

<div class="container mt-5">
    <div class="row">
        <div class="col-lg-2"></div>

        <div class="col-lg-8 my-3">
            <h1 class="text-center">Criar conta ou Entrar</h1>
            <p class="text-center lead">Faça login ou crie sua conta abaixo</p>
    
            <div class="row row-cols-1 row-cols-lg-2 g-4">
                <div class="col-lg">
                    <h4>Faça seu cadastro</h4>
                    <p>Se você ainda não tem conta, preencha o formulário abaixo:</p>

                    <form action="/login/register" method="POST">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <div class="form-group">
                            <label>Seu email</label>
                            <input type="email" class="form-control" name="email">
                            
                        </div>
                        <div class="form-group">
                            <label>Sua senha</label>
                            <input type="password" class="form-control" name="password">
                        </div>
                        <button type="submit" class="btn btn-primary my-3" style="background-color: hotpink; border: none;">Criar minha conta</button>
                    </form>

                </div>

                <div class="col-lg">
                    <h4>Faça seu Login</h4>
                    <p>Se você já tem uma conta, faça login abaixo:</p>

                    <form action="/login/login" method="POST">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <div class="form-group">
                            <label>Seu email</label>
                            <input type="email" class="form-control" name="email">
                            
                        </div>
                        <div class="form-group">
                            <label>Sua senha</label>
                            <input type="password" class="form-control" name="password">
                        </div>
                        <button type="submit" class="btn btn-primary my-3" style="background-color: hotpink; border: none;">Entrar</button>
                    </form>
                </div>
            </div>

        </div>

        <div class="col-lg-2"></div>
    </div>
</div>

<%- include('includes/footer') %>